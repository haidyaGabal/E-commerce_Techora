@model CustomersCatsItemsModel

@section Styles {

    
   
}

<!-- Hero Section Begin -->
@if (TempData["OrderSuccess"] != null)
{
    <script>
        alert('@TempData["OrderSuccess"]');
    </script>
}
<section class="hero py-5">
    <div class="container">
        <div class="row">

            <!-- Left Column (Brand + Categories) -->
            <div class="col-lg-3 mb-4">
                <div class="hero__text text-center mb-4">
                    <h2 class="fw-bold" style="color:#446694;">Techora</h2>
                </div>

                <div class="hero__categories bg-light rounded shadow-sm p-3">
                    <div class="hero__categories__all d-flex align-items-center mb-2">
                        <i class="fa fa-bars me-2"></i>
                        <span class="fw-semibold">All Departments</span>
                    </div>
                    <ul class="list-unstyled">
                        @foreach (var cat in Model.lstCategory)
                        {
                            <li class="mb-2">
                                <a class="text-dark text-decoration-none"
                                   asp-controller="Categories"
                                   asp-action="Edit"
                                   asp-route-categoryId="@cat.CategoryId">
                                    @cat.CategoryName
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
            <div class="col-lg-9">
                <!-- Search Bar -->
                <div class="position-relative mb-3">
                    <div class="input-group shadow rounded-pill overflow-hidden border border-2">
                        <span class="input-group-text bg-white border-0">
                            <i class="mdi mdi-magnify text-primary fs-5"></i>
                        </span>
                        <input type="text"
                               class="form-control border-0"
                               id="navbar-search-input"
                               placeholder="Search products..."
                               autocomplete="off"
                               style="box-shadow:none;">
                    </div>

                    <!-- Search Results Dropdown -->
                    <ul id="projectList"
                        class="list-group position-absolute w-100 mt-2 shadow-lg rounded"
                        style="display: none; z-index: 1000; max-height:250px; overflow-y:auto;">
                        @foreach (var item in Model.lstProduct)
                        {
                           <li class="list-group-item list-group-item-action">
                                <a asp-controller="ProductDetail"
                                   asp-action="ProductFullDetails"
                                   asp-route-ProductId="@item.ProductId">
                                    @item.ProductName
                                </a> 
                            </li>
                            
                        }
                    </ul>
                </div>

             


                <div class="hero__item set-bg" data-setbg="@Url.Content("~/FrontEnd/img/hero/bg5.jpg")">
                    <div class="hero__text">
                        <span>FRUIT FRESH</span>
                        <h2>Vegetable <br />100% Organic</h2>
                        <p>Free Pickup and Delivery Available</p>
                        <a href="#" class="primary-btn">SHOP NOW</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Hero Section End -->
<!-- Categories Section Begin -->
<section class="categories">
    <div class="container">
        <div class="row">
            <div class="categories__slider owl-carousel">
                @foreach (var cat in Model.lstCategory)
                {
                    <div class="col-lg-3">
                        <div class="categories__item set-bg"
                             style="padding:20px; border:1px solid #446694; border-radius:12px; text-align:center;">

                            <img src="~/Admin/CateoryImges/@cat.ImageName"
                                 alt="@cat.CategoryName"
                                 style="width:180px; height:180px; object-fit:cover; display:block; margin:0 auto 15px auto; border-radius:12px;" />

                            <h5 style="margin-top:10px;">
                                <a href="#" style="text-decoration:none;background-color:#446694;opacity:0.9">@cat.CategoryName</a>
                            </h5>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
<!-- Categories Section End -->
<!-- Featured Section Begin -->
<section class="featured spad">
    <div class="container">
        <!-- Section Header -->
        <div class="row mb-4">
            <div class="col-lg-12 text-center">
                <div class="section-title">
                    <h2 class="fw-bold">Featured Products</h2>
                </div>
                <!-- Category Filter -->
                <div class="featured__controls mt-3">
                    <ul class="d-flex justify-content-center flex-wrap gap-3">
                        <li class="active" data-filter="*">All</li>
                        @foreach (var cat in Model.lstCategory)
                        {
                            <li data-filter=".cat-@cat.CategoryId">@cat.CategoryName</li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Product Grid -->
        <div>
            <div class="row featured__filter g-4" id="product-list">
                @foreach (var item in Model.lstProduct)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 mix product-card cat-@item.CategoryId">
                        <div class="featured__item shadow-sm rounded-3 border h-100">
                            <!-- Product Image -->
                            <div class="featured__item__pic position-relative set-bg"
                                 data-setbg="@(item.ProductImages?.FirstOrDefault()?.ImageUrl ?? Url.Content("~/FrontEnd/img/default-product.png"))"
                                 style="height:250px; background-size:cover; background-position:center;">
                                <ul class="featured__item__pic__hover position-absolute bottom-0 start-50 translate-middle-x d-flex gap-2 mb-2">
                                    <!-- Wishlist -->
                                    <li>
                                        <a href="#" title="Add to Wishlist" class="bg-danger text-white">
                                            <i class="fa fa-heart"></i>
                                        </a>
                                    </li>
                                    <!-- Shopping Cart -->
                                    <li>
                                        <a asp-controller="ProductDetail"
                                           asp-action="ProductFullDetails"
                                           asp-route-ProductId="@item.ProductId" title="View Product" class="bg-primary text-white">
                                            <i class="fa fa-shopping-cart"></i>
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <!-- Product Info -->
                            <div class="featured__item__text text-center p-3">
                                <h6 class="fw-semibold">@item.ProductName</h6>
                                <h5 class="text-primary">@item.Price.ToString("C")</h5>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Custom Pagination (DataTables style) -->
            <div class="row">
                <div class="col-sm-12 col-md-5">
                    <div class="dataTables_info" id="order-listing_info" role="status" aria-live="polite">
                       
                    </div>
                </div>
                <div class="col-sm-12 col-md-7">
                    <div class="dataTables_paginate paging_simple_numbers" id="order-listing_paginate">
                        <ul class="pagination justify-content-center">
                            <li class="paginate_button page-item previous disabled" id="order-listing_previous">
                                <a href="#" aria-controls="order-listing" data-dt-idx="0" tabindex="0" class="page-link">Previous</a>
                            </li>
                            <li class="paginate_button page-item active">
                                <a href="#" aria-controls="order-listing" data-dt-idx="1" tabindex="0" class="page-link">1</a>
                            </li>
                            <li class="paginate_button page-item next disabled" id="order-listing_next">
                                <a href="#" aria-controls="order-listing" data-dt-idx="2" tabindex="0" class="page-link">Next</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <!-- End Pagination -->

        </div>
    </div>
</section>

<!-- Featured Section End -->
<!-- Banner Begin -->
<div class="banner">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-6 col-sm-6">
                <div class="banner__pic">
                    <img src="img/banner/banner-1.jpg" alt="">
                </div>
            </div>
            <div class="col-lg-6 col-md-6 col-sm-6">
                <div class="banner__pic">
