@section Scripts {


    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const filterItems = document.querySelectorAll(".featured__controls li");
            const productCards = Array.from(document.querySelectorAll(".product-card"));
            const paginationList = document.querySelector(".pagination");
            const perPage = 8;
            let currentPage = 1;
            let filteredCards = [...productCards];

            if (!filterItems.length || !productCards.length || !paginationList) return;

            const showPage = (page = 1) => {
                currentPage = page;
                const start = (page - 1) * perPage;
                const end = start + perPage;

                filteredCards.forEach((card, i) => {
                    card.style.display = i >= start && i < end ? "" : "none"; // preserve grid
                });

                const totalPages = Math.ceil(filteredCards.length / perPage);
                paginationList.innerHTML = "";

                // Previous
                const prevLi = document.createElement("li");
                prevLi.className = `paginate_button page-item ${page === 1 ? "disabled" : ""}`;
                prevLi.innerHTML = `<a href="#" class="page-link">Previous</a>`;
                prevLi.addEventListener("click", e => { e.preventDefault(); if (currentPage > 1) showPage(currentPage - 1); });
                paginationList.appendChild(prevLi);

                // Page numbers
                for (let i = 1; i <= totalPages; i++) {
                    const li = document.createElement("li");
                    li.className = `paginate_button page-item ${i === page ? "active" : ""}`;
                    li.innerHTML = `<a href="#" class="page-link">${i}</a>`;
                    li.addEventListener("click", e => { e.preventDefault(); showPage(i); });
                    paginationList.appendChild(li);
                }

                // Next
                const nextLi = document.createElement("li");
                nextLi.className = `paginate_button page-item ${page === totalPages ? "disabled" : ""}`;
                nextLi.innerHTML = `<a href="#" class="page-link">Next</a>`;
                nextLi.addEventListener("click", e => { e.preventDefault(); if (currentPage < totalPages) showPage(currentPage + 1); });
                paginationList.appendChild(nextLi);
            };

            const filterProducts = (filterClass) => {
                if (filterClass === "*") {
                    filteredCards = [...productCards]; // show all
                } else {
                    const className = filterClass.replace(".", "");
                    filteredCards = productCards.filter(card => card.classList.contains(className));
                }
                showPage(1);
            };

            filterItems.forEach(li => {
                li.addEventListener("click", () => {
                    filterItems.forEach(x => x.classList.remove("active"));
                    li.classList.add("active");

                    const filter = li.getAttribute("data-filter");
                    filterProducts(filter);
                });
            });

            // Initial load
            filterProducts("*");
        });
    </script>

















    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const itemsPerPage = 8; // ✅ Show 6 items per page
            const items = document.querySelectorAll(".product-card");
            const pagination = document.getElementById("pagination");

            if (!items.length || !pagination) return;

            const totalPages = Math.ceil(items.length / itemsPerPage);

            function showPage(page) {
                items.forEach((item, index) => {
                    item.style.display = (index >= (page - 1) * itemsPerPage && index < page * itemsPerPage)
                        ? "block"
                        : "none";
                });
            }

            // Create pagination buttons
            for (let i = 1; i <= totalPages; i++) {
                const li = document.createElement("li");
                li.className = "page-item";
                li.innerHTML = `<a class="page-link" href="#">${i}</a>`;
                li.addEventListener("click", function (e) {
                    e.preventDefault();
                    showPage(i);

                    // Highlight active page
                    document.querySelectorAll("#pagination .page-item").forEach(el => el.classList.remove("active"));
                    li.classList.add("active");
                });
                pagination.appendChild(li);
            }

            // Show first page by default
            showPage(1);
            pagination.querySelector(".page-item").classList.add("active");
        });
    </script>


    <script>
        const searchInput = document.getElementById("navbar-search-input");
        const projectList = document.getElementById("projectList");
        const items = projectList.querySelectorAll("li");
        let currentIndex = -1;

        function resetHighlight() {
          items.forEach(item => item.classList.remove("active"));
        }

        searchInput.addEventListener("keyup", function(e) {
          let filter = this.value.toLowerCase();

          if (filter.trim() === "") {
            projectList.style.display = "none";
            currentIndex = -1;
            return;
          }

          projectList.style.display = "block";
          let hasResult = false;

          items.forEach(item => {
            if (item.textContent.toLowerCase().includes(filter)) {
              item.style.display = "";
              hasResult = true;
            } else {
              item.style.display = "none";
            }
          });

          if (!hasResult) {
            projectList.style.display = "none";
          }

          // Handle keyboard navigation
          if (e.key === "ArrowDown") {
            currentIndex = (currentIndex + 1) % items.length;
            resetHighlight();
            if (items[currentIndex].style.display !== "none") {
              items[currentIndex].classList.add("active");
            }
          } else if (e.key === "ArrowUp") {
            currentIndex = (currentIndex - 1 + items.length) % items.length;
            resetHighlight();
            if (items[currentIndex].style.display !== "none") {
              items[currentIndex].classList.add("active");
            }
          } else if (e.key === "Enter" && currentIndex >= 0) {
            alert("Selected: " + items[currentIndex].textContent);
            searchInput.value = items[currentIndex].textContent;
            projectList.style.display = "none";
          }
        });

        // Close dropdown when clicking outside
        document.addEventListener("click", function(event) {
          if (!searchInput.contains(event.target) && !projectList.contains(event.target)) {
            projectList.style.display = "none";
          }
        });
    </script>
}
