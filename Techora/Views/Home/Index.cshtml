    </div>
</div>
<!-- Banner End -->
<!-- Latest Product Section Begin -->
<section class="latest-product spad">
    <div class="container">
        <div class="row">
            <!-- Latest Products -->
            <div class="col-lg-4 col-md-6">
                <div class="latest-product__text">
                    <h4>Latest Products</h4>
                    <div class="latest-product__slider owl-carousel">
                        @foreach (var items in Model.LatestProducts.Select((p, i) => new { Product = p, Index = i }).GroupBy(x => x.Index / 3))
                        {
                            <div class="latest-prdouct__slider__item">
                                @foreach (var item in items)
                                {
                                    <a href="#" class="latest-product__item">
                                        <div class="latest-product__item__pic"
                                             style="width:120px; height:120px; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                                            <img src="@(item.Product.ProductImages?.FirstOrDefault()?.ImageUrl ?? Url.Content(""))"
                                                 alt="@item.Product.ProductName"
                                                 style="width:100%; height:100%; object-fit:contain;" />
                                        </div>
                                        <div class="latest-product__item__text">
                                            <h6>@item.Product.ProductName</h6>
                                            <span>@item.Product.Price.ToString("C")</span>
                                        </div>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Wishlist -->
            <div class="col-lg-4 col-md-6">
                <div class="latest-product__text">
                    <h4>WishList Products</h4>
                    <div class="latest-product__slider owl-carousel">
                        @foreach (var items in Model.Wishlists.Select((p, i) => new { Product = p, Index = i }).GroupBy(x => x.Index / 3))
                        {
                            <div class="latest-prdouct__slider__item">
                                @foreach (var item in items)
                                {
                                    <a href="#" class="latest-product__item">
                                        <div class="latest-product__item__pic"
                                             style="width:120px; height:120px; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                                            <img src="@(item.Product.Product.ProductImages?.FirstOrDefault()?.ImageUrl ?? Url.Content(""))"
                                                 alt="@item.Product.Product.ProductName"
                                                 style="width:100%; height:100%; object-fit:contain;" />
                                        </div>
                                        <div class="latest-product__item__text">
                                            <h6>@item.Product.Product.ProductName</h6>
                                            <span>@item.Product.Product.Price.ToString("C")</span>
                                        </div>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Review Products -->
            <div class="col-lg-4 col-md-6">
                <div class="latest-product__text">
                    <h4>Review Products</h4>
                    <div class="latest-product__slider owl-carousel">
                        @foreach (var group in Model.ReviewProducts
                                                .Select((r, i) => new { Review = r, Index = i })
                                                .GroupBy(x => x.Index / 3))
                        {
                            <div class="latest-prdouct__slider__item">
                                @foreach (var item in group)
                                {
                                    <a href="#" class="latest-product__item" style="display:flex; gap:10px; align-items:center; margin-bottom:10px;">
                                        <!-- Product Image -->
                                        <div class="latest-product__item__pic"
                                             style="width:100px; height:120px; flex-shrink:0; display:flex; align-items:center; justify-content:center; overflow:hidden; border-radius:8px; border:1px solid #eee;">
                                            <img src="@(item.Review.Product.ProductImages?.FirstOrDefault()?.ImageUrl
                                                                                                 ?? Url.Content("~/FrontEnd/img/default-product.png"))"
                                         alt="@item.Review.Product.ProductName"
                                         style="max-width:100%; max-height:100%; object-fit:contain;" />
                                </div>
                                <!-- Product + Review Info -->
                                <div class="latest-product__item__text" style="flex:1;">
                                    <h6 style="margin:0; font-size:14px; font-weight:600;">@item.Review.Product.ProductName</h6>
                                    <p style="margin:2px 0; font-size:12px; color:#666;">@item.Review.Comment</p>
                                    <span>@item.Review.Product.Price.ToString("C")</span>
                                </div>
                            </a>
                                                        }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
