@model ShoppingCart

<!-- Breadcrumb Section Begin -->
<section class="breadcrumb-section set-bg" data-setbg="~/FrontEnd/img/breadcrumb.jpg">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 text-center">
                <div class="breadcrumb__text">
                    <h2>Shopping Cart</h2>
                    <div class="breadcrumb__option">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                        <span>Shopping Cart</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Breadcrumb Section End -->
<!-- Shopping Cart Section Begin -->
<section class="shoping-cart spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="shoping__cart__table">
                    <table>
                        <thead>
                            <tr>
                                <th class="shoping__product">Products</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>


                            @if (Model != null && Model.Products.Any())
                            {
                                foreach (var item in Model.Products)
                                {
                                    <tr>
                                        <td class="shoping__cart__item">
                                            <img src="@Url.Content(item.ImageUrl ?? "~/FrontEnd/img/no-image.jpg")" alt="@item.ProductName" width="85">

                                            <h5>@item.ProductName</h5>
                                        </td>
                                        <td class="shoping__cart__price">
                                            $@item.Price
                                        </td>
                                        <td class="shoping__cart__quantity">
                                            <div class="quantity">

                                                <input type="number" value="@item.Qty"
                                                       min="1"
                                                       data-price="@item.Price"
                                                       class="qty-input pro-qty" />

                                            </div>
                                        </td>
                                        <td class="shoping__cart__total total-cell">
                                            $@(item.Qty* item.Price)
                                        </td>





                                        <td class="shoping__cart__item__close">
                                            <a asp-action="Remove" asp-route-cartId="@item.CartId">
                                                <span class="icon_close"></span>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Cart buttons and summary -->
        <div class="row">
            <div class="col-lg-12">
                <div class="shoping__cart__btns">
                    <a asp-controller="Home" asp-action="Index" class="primary-btn cart-btn">CONTINUE SHOPPING</a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="shoping__continue">
                    <div class="shoping__discount">
                        <h5>Discount Codes</h5>
                        <form asp-controller="Orders" asp-action="AddToCart" method="post">
                            @foreach (var item in Model.Products)
                            {
                                <input type="hidden" name="productId" value="@item.ProductId" />
                            }


                            <input name="PromoCode" type="text" placeholder="Enter your coupon code" />
                            <button type="submit" class="site-btn">APPLY COUPON</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">

                <div class="shoping__checkout">
                    <h5>Cart Total</h5>
                    <ul>
                        <li>Subtotal <span>$@Model.SubTotal</span></li>
                        <li>Total <span>$@Model.Total</span></li>
                    </ul>
                    <a asp-controller="Orders" asp-action="Checkout" class="primary-btn">PROCEED TO CHECKOUT</a>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Shopping Cart Section End -->
@section Scripts {
    <script>

        document.querySelectorAll(".qty-input").forEach(input => {
            input.addEventListener("input", function () {
                const price = parseFloat(this.dataset.price);
                const qty = parseInt(this.value) || 0;
                const totalCell = this.closest("tr").querySelector(".total-cell");
                totalCell.innerText = "$" + (price * qty).toFixed(2);
            });
        });
    </script>



}
