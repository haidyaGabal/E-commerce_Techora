@{
    Layout = null;
}
@model UserModel

<!-- page-wrapper Start-->
<div class="page-wrapper bg-light min-vh-100 d-flex align-items-center">
    <div class="authentication-box container">
        <div class="row justify-content-center shadow-lg rounded-3 overflow-hidden bg-white">

            <!-- Shared left side -->
            <div class="col-lg-5 p-0 d-none d-lg-block card-left">
                <!-- KEEP YOUR SVG/SLIDER CODE HERE -->
            </div>

            <!-- Register form -->
            <div class="col-lg-7 p-4 card-right">
                <div class="card border-0">
                    <div class="card-body p-4">

                        <!-- Heading -->
                        <h3 class="text-center fw-bold mb-3">Create Your Account 🚀</h3>
                        <p class="text-muted text-center mb-4">Join us and start your journey today</p>

                        <form method="post" asp-controller="Account" asp-action="Register" class="auth-form">

                            <!-- First Name -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="FirstName">First Name</label>
                                <input asp-for="FirstName" required type="text" class="form-control form-control-lg" placeholder="Enter first name">
                             <span asp-validation-for="FirstName"></span>

                            </div>

                            <!-- Last Name -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="LastName">Last Name</label>
                                <input asp-for="LastName"  required type="text" class="form-control form-control-lg" placeholder="Enter last name">
                                  <span asp-validation-for="LastName"></span>
                            </div>

                            <!-- Email -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="Email">Email</label>
                                <input asp-for="Email" required type="email" class="form-control form-control-lg" placeholder="Enter email address">
                                <span asp-validation-for="Email"></span>
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="Password">Password</label>
                                <input asp-for="Password" required type="password" class="form-control form-control-lg" placeholder="Enter password">
                                <span asp-validation-for="Password"></span>
                            </div>

                            <!-- Confirm Password -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="ConfirmPassword">Confirm Password</label>
                                <input asp-for="ConfirmPassword" required type="password" class="form-control form-control-lg" placeholder="Confirm password">
                                <span asp-validation-for="ConfirmPassword"></span>
                            </div>

                            <!-- Terms -->
                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="termsCheck" required>
                                <label class="form-check-label" for="termsCheck">
                                    I agree to the <a href="#" class="fw-semibold text-primary">Terms & Conditions</a>
                                </label>
                            </div>

                            <!-- Register Button -->
                            <div class="d-grid mb-3">
                                <button class="btn btn-primary btn-lg rounded-pill" type="submit">Register</button>
                            </div>

                            <!-- Social Signup -->
                            <div class="text-center mt-3">
                                <span class="d-block mb-2 text-muted">Or sign up with</span>
                                <div class="d-flex justify-content-center gap-3">
                                    <a href="#" class="btn btn-outline-primary rounded-circle">
                                        <i class="icon-facebook"></i>
                                    </a>
                                    <a href="#" class="btn btn-outline-info rounded-circle">
                                        <i class="icon-twitter"></i>
                                    </a>
                                    <a href="#" class="btn btn-outline-danger rounded-circle">
                                        <i class="icon-instagram"></i>
                                    </a>
                                    <a href="#" class="btn btn-outline-dark rounded-circle">
                                        <i class="icon-pinterest"></i>
                                    </a>
                                </div>
                            </div>
                        </form>

                        <!-- Login Link -->
                        <p class="mt-4 text-center">
                            Already have an account?
                            <a href="/Account/Login" class="fw-semibold text-primary">Login</a>
                            
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Back Button -->
        <div class="text-center mt-4">
            <a href="/" class="btn btn-outline-secondary rounded-pill">
                <i data-feather="arrow-left"></i> Back to Home
            </a>
        </div>
    </div>
</div>

<script>
    $('.single-item').slick({
        arrows: false,
        dots: true
    });
</script>
