@{
    Layout = null;
}
@model UserModel

<!-- page-wrapper Start-->
<div class="page-wrapper bg-light min-vh-100 d-flex align-items-center">
    <div class="authentication-box container">
        <div class="row justify-content-center shadow-lg rounded-3 overflow-hidden bg-white">

            <!-- Left side (SVG/Slider) -->
            <div class="col-lg-5 p-0 d-none d-lg-block card-left">
                <!-- Add your SVG or slider here -->
            </div>

            <!-- Login Form -->
            <div class="col-lg-7 p-4 card-right">
                <div class="card border-0">
                    <div class="card-body p-4">

                        <!-- Heading -->
                        <h3 class="text-center fw-bold mb-4">Welcome Back 👋</h3>
                        <p class="text-muted text-center mb-4">Login to continue to your account</p>

                        <form method="post" asp-controller="Account" asp-action="Login" class="auth-form">
                            <input type="hidden" asp-for="ReturnUrl" />

                            <!-- Email -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="Email">Email</label>
                                <input asp-for="Email" required type="email" class="form-control form-control-lg" placeholder="Enter your email">
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="Password">Password</label>
                                <input asp-for="Password" required type="password" class="form-control form-control-lg" placeholder="Enter your password">
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <!-- Remember + Forgot -->
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="rememberMe">
                                    <label class="form-check-label" for="rememberMe">Remember me</label>
                                </div>
                                <a href="#" class="text-decoration-none text-primary fw-semibold">Forgot Password?</a>
                            </div>

                            <!-- Login Button -->
                            <div class="d-grid mb-3">
                                <button class="btn btn-primary btn-lg rounded-pill" type="submit">Login</button>
                            </div>

                            <!-- Social Login -->
                            <div class="text-center mt-3">
                                <span class="d-block mb-2 text-muted">Or login with</span>
                                <div class="d-flex justify-content-center gap-3">
                                    <a href="#" class="btn btn-outline-primary rounded-circle shadow-sm p-3">
                                        <i class="icon-facebook"></i>
                                    </a>
                                    <a href="#" class="btn btn-outline-info rounded-circle shadow-sm p-3">
                                        <i class="icon-twitter"></i>
                                    </a>
                                    <a href="#" class="btn btn-outline-danger rounded-circle shadow-sm p-3">
                                        <i class="icon-instagram"></i>
                                    </a>
                                    <a href="#" class="btn btn-outline-dark rounded-circle shadow-sm p-3">
                                        <i class="icon-pinterest"></i>
                                    </a>
                                </div>
                            </div>
                        </form>


                        <div class="mt-4 text-center">
                            <p>
                                Go To Admin Panel
                                <button id="admin-btn" class="btn btn-link fw-semibold text-primary p-0">Admin Panel</button>
                            </p>

                            <p id="register-section">
                                Don’t have an account?
                                <a href="/Account/Register" class="fw-semibold text-primary">Register</a>
                            </p>
                        </div>

                        <script>
                            document.addEventListener("DOMContentLoaded", () => {
                                const adminBtn = document.getElementById("admin-btn");
                                const registerSection = document.getElementById("register-section");

                                adminBtn.addEventListener("click", () => {
                                    // Hide the register section immediately
                                    registerSection.style.display = "none";

                                    // Navigate after 1 second
                                    setTimeout(() => {
                                        window.location.href = "/Admin/Home";
                                    }, 1000000); // 1 second delay
                                });
                            });
                        </script>





                       

                    </div>
                </div>
            </div>
        </div>

        <!-- Back Button -->
        <div class="text-center mt-4">
            <a href="/" class="btn btn-outline-secondary rounded-pill">
                <i data-feather="arrow-left"></i> Back to Home
            </a>
        </div>
    </div>
</div>

<!-- Optional: Slick Slider Script -->
<script>
    $('.single-item').slick({
        arrows: false,
        dots: true
    });
</script>
