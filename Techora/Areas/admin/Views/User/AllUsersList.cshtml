@model UsersListModel

@section Styles {
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.css"> <!-- End plugin css for this page -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"> <!-- DataTables + Bootstrap 5 CSS -->
}

<div class="container ">

    <!-- Top Cards Row -->
    <div class="row justify-content-center mb-4">
        <!-- Borrowed Card -->
        <div class="col-md-3">
            <div class="card text-center shadow border-success">
                <div class="card-body">
                    <h6 class="card-title text-success">Number Of Admin / Data Entry</h6>

                    <h4 class="fw-light border-top pb-2 mb-2">@Model.lstAdmin.Count </h4>

                </div>
            </div>
        </div>

        <!-- Annual Profit Card -->
        <div class="col-md-3">
            <div class="card text-center shadow border-danger">
                <div class="card-body">
                    <h6 class="card-title text-danger">Number Of Customers</h6>

                    <h4 class="fw-light border-top pb-2 mb-2">@Model.lstCustomer.Count </h4>

                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card shadow">
        <div class="card-body">
            <h6 class="card-title mb-3">Hoverable Table</h6>
            <div class="table-responsive">
                <table id="order-listing" class="table table-hover table-striped table-bordered align-middle">
                    
                    <thead class="table-primary">
                        <tr>

                            <th class="text-center">FullName</th>
                            <th class="text-center">Email (g)</th>
                            <th class ="text-center">PhoneNumber</th>
                        

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.lstCustomer)
                        {
                            <tr>

                                <td class="text-start">@user.FullName <small><mark>Customer</mark></small></td>
                                <td class="text-start">@user.Email</td>
                                <td class="text-start">@user.PhoneNumber</td>
                              

                            </tr>
                        }
                        @foreach (var user in Model.lstAdmin)
                        {
                            <tr>

                                <td class="text-start">@user.FullName <small><mark>@user.RoleType</mark></small></td>
                                <td class="text-start">@user.Email</td>
                                <td class="text-start">@user.PhoneNumber</td>


                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts
{

    <script src="~/Admin/assets/vendors/datatables.net/jquery.dataTables.js"></script>
    <script src="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.js"></script>
    <script src="~/Admin/assets/js/data-table.js"></script>

}
