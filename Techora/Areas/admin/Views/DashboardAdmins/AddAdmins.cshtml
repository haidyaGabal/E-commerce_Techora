@model Techora.Models.Admin

<div class="d-flex align-items-center justify-content-center vh-100 ">
    <div class="card shadow-lg border-0" style="max-width: 500px; width: 100%; border-radius: 16px; overflow: hidden;">

        <!-- Card Header -->
        <div class="text-white text-center py-4 " style=" background-color: rgb(207, 226, 255);">
            <h4 class="mb-1 fw-bold">Add Admin / Data Entry</h4>
            <p class="mb-0 small text-white-50">Create a new account with proper role assignment</p>
        </div>
       
        <!-- Card Body -->
        <div class="card-body p-4">
            <form asp-controller="DashboardAdmins" asp-action="Save" method="post" enctype="multipart/form-data" role="form">

                <!-- Full Name -->
                <div class="row mb-3">
                    <label asp-for="FullName" class="col-sm-4 col-form-label text-end">Full Name</label>
                    <div class="col-sm-8">
                        <input asp-for="FullName" class="form-control" placeholder="Enter full name" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <label asp-for="Email" class="col-sm-4 col-form-label text-end">Email</label>
                    <div class="col-sm-8">
                        <input asp-for="Email" type="email" class="form-control" placeholder="Enter email address" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <label asp-for="PasswordHash" class="col-sm-4 col-form-label text-end">Password</label>
                    <div class="col-sm-8">
                        <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Enter password" />
                        <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <label asp-for="PhoneNumber" class="col-sm-4 col-form-label text-end">Phone Number</label>
                    <div class="col-sm-8">
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <label asp-for="RoleType" class="col-sm-4 col-form-label text-end">Role Type</label>
                    <div class="col-sm-8">
                        <select asp-for="RoleType" class="form-select">
                            <option value="">-- Select Role --</option>
                            <option value="Admin">Admin</option>
                            <option value="DataEntry">Data Entry</option>
                        </select>
                        <span asp-validation-for="RoleType" class="text-danger small"></span>
                    </div>
                </div>


                <!-- Actions -->
                <div class="d-flex justify-content-between">
                    <button type="reset" class="btn btn-outline-secondary px-4">Reset</button>
                    <button type="submit" class="btn btn-primary px-4">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
    
        .card {
            margin-top: 100px;
            border-radius: 16px;
            background-color: rgb(242, 242, 242);
            height:600px;
            width:500px;
        }

        .form-control, .form-select {
            border-radius: 8px;
            padding: 15px 18px;
            border: 1px solid #dee2e6;
            width:70%;
           
        }
     
            .form-control:focus, .form-select:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
            }

        .btn {
            border-radius: 8px;
            font-weight: 500;
           
        }

        .btn-primary {
            background-color: rgb(207, 226, 255);
            border: none;
        }

            .btn-primary:hover {
                background-color: #0b5ed7;
            }

        .btn-outline-secondary:hover {
            background-color: #f1f3f5;
        }

        .col-form-label {
            font-weight: 400;
            color: #333;
        }


    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
