@model CustomersCatsItemsModel

@section Styles {
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.css"> <!-- End plugin css for this page -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"> <!-- DataTables + Bootstrap 5 CSS -->
}

<div class="container ">

    <!-- Top Cards Row -->
    <div class="row justify-content-center mb-4">
        <!-- Borrowed Card -->
        <div class="col-md-3">
            <div class="card text-center shadow border-success">
                <div class="card-body">
                    <h5 class="card-title text-success">Number Of Categories</h5>
                    
                    <h4 class="fw-light border-top pb-2 mb-2">@Model.lstCategory.Count category</h4>
                  
                </div>
            </div>
        </div>

        <!-- Annual Profit Card -->
        <div class="col-md-3">
            <div class="card text-center shadow border-danger">
                <div class="card-body">
                    <h5 class="card-title text-danger">Number Of Items</h5>
                 
                    <h4 class="fw-light border-top pb-2 mb-2">@Model.lstProduct.Count Item</h4>
                   
                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card shadow">
        <div class="card-body">
            <h6 class="card-title mb-3">Hoverable Table</h6>
            <div class="table-responsive">
                <table id="order-listing" class="table table-hover table-striped table-bordered align-middle">
                     <thead class="table-primary">
                        <tr>
                 
                            <th class="text-start">Product Name</th>
                            <th>Category Name</th>
                            <th>Stock</th>
                            <th>CurrentState</th>
                            <th>CreatedAt (g)</th>
                         
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model?.lstProduct != null && Model.lstProduct.Any())
                        {
                            foreach (var user in Model.lstProduct)
                            {
                                <tr>
                                    <td class="text-start">@user.ProductName</td>
                                    <td>@(user.Category != null ? user.Category.CategoryName : "No Category")</td>
                                    <td>
                                        @if (user.CurrentState == 1 && user.Stock!=0)
                                        {
                                            <span class="text-muted">@user.Stock</span>
                                        }
                                        else 
                                        {
                                            <span class="text-muted">Not Available</span>
                                        }
                                    </td>
                                    <td>
                                        @if (user.CurrentState == 1 && user.Stock != 0)
                                        {
                                            <span class="text-muted">Available</span>
                                        }
                                        else 
                                        {
                                            <span class="text-muted">Not Available</span>
                                        }
                                    </td>
                                    <td>@user.CreatedAt</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts
{

    <script src="~/Admin/assets/vendors/datatables.net/jquery.dataTables.js"></script>
    <script src="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.js"></script>
    <script src="~/Admin/assets/js/data-table.js"></script>

}
