@model Product





@section Styles {
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.css"> <!-- End plugin css for this page -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"> <!-- DataTables + Bootstrap 5 CSS -->
}





<div class="content-wrapper">
    <div class="page-header">
        <h3 class="card-title mb-3">Product Form</h3>
    </div>
    <div class="row g-3">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data"
                          asp-controller="Items" asp-action="Save">

                        <input type="hidden" asp-for="ProductId" />
                        <input type="hidden" asp-for="CategoryId" />
                      
                        <input type="hidden" asp-for="ProductFullDetail.ProductId" />

                        <input type="hidden" asp-for="ProductFullDetail.DetailId" />

                   
                        

                        <!-- Product Name -->
                        <div class="mb-3">
                            <label asp-for="ProductName" class="form-label">Product Name</label>
                            <input asp-for="ProductName" class="form-control" />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>
                   
                        <!-- Price -->
                        <div class="mb-3">
                            <label asp-for="Price" class="form-label">Price</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>

                        <!-- Stock -->
                        <div class="mb-3">
                            <label asp-for="Stock" class="form-label">Stock</label>
                            <input asp-for="Stock" class="form-control" type="number" />
                        </div>

                        <!-- Product Details -->
                        <h6 class="fw-bold mt-4">Product Details</h6>
                        <div class="mb-3">
                            <label asp-for="ProductFullDetail.Brand" class="form-label">Brand</label>
                            <input asp-for="ProductFullDetail.Brand" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="ProductFullDetail.Model" class="form-label">Model</label>
                            <input asp-for="ProductFullDetail.Model" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="ProductFullDetail.Processor" class="form-label">Processor</label>
                            <input asp-for="ProductFullDetail.Processor" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="ProductFullDetail.Ram" class="form-label">RAM</label>
                            <input asp-for="ProductFullDetail.Ram" class="form-control" />
                        </div>



                        <!-- Upload New Images -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Upload Images</label>
                            <input type="file" name="files" class="form-control" multiple accept=".jpg,.jpeg,.png"
                                   onchange="previewImages(event)" />
                        </div>

                        <!-- Already Uploaded Images -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Existing Images</label>
                            <div class="d-flex flex-wrap gap-2">
                                @if (Model.ProductImages != null && Model.ProductImages.Any())
                                {
                                    foreach (var img in Model.ProductImages)
                                    {
                                        
                                        <div class="position-relative">
                                            <img src="@img.ImageUrl" class="img-thumbnail" style="width:120px; height:120px; object-fit:cover;" />
                                            <a asp-action="DeleteImage" asp-route-id="@img.ImageId"
                                               class="btn btn-sm btn-danger position-absolute top-0 end-0">x</a>
                                        </div>

                                       
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No images uploaded yet.</span>
                                }
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4">Save</button>
                            <button type="reset" class="btn btn-light px-4">Reset</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Preview New Uploads -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body text-center">
                    <h6 class="fw-semibold mb-3">Preview</h6>
                    <div id="tbImgSrc" class="border rounded p-2 bg-light"></div>
                </div>
            </div>
        </div>
    </div>
</div>




@section Scripts
{
    <script>
        function previewImages(event) {
            const files = event.target.files;
            const container = document.getElementById("tbImgSrc");
            container.innerHTML = ""; // clear old preview

            Array.from(files).forEach(file => {
                const reader = new FileReader();
                reader.onload = e => {
                    const img = document.createElement("img");
                    img.src = e.target.result;
                    img.classList.add("img-thumbnail", "m-1");
                    img.style.width = "100px";
                    img.style.height = "100px";
                    img.style.objectFit = "cover";
                    container.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        }
    </script>




    <script src="~/Admin/assets/vendors/datatables.net/jquery.dataTables.js"></script>
    <script src="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.js"></script>
    <script src="~/Admin/assets/js/data-table.js"></script>

}
