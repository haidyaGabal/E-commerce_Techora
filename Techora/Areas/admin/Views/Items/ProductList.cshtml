@model List<Product>


@section Styles {
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.css"> <!-- End plugin css for this page -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"> <!-- DataTables + Bootstrap 5 CSS -->
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-3">
      

        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="card-title mb-0">Categories</h6>
                <a asp-controller="Items" asp-action="Edit" class="btn btn-success btn-sm">
                    <i class="bi bi-plus-lg"></i> New
                </a>
            </div>
            <!-- Category Filter -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <label for="categoryFilter" class="form-label fw-bold">Filter by Category</label>
                    <select id="categoryFilter" class="form-select"
                            asp-items="@(new SelectList(ViewBag.lstCategories, "CategoryId", "CategoryName", ViewBag.SelectedCategoryId))"
                            onchange="Search(this)">
                        <option value="">-- All Categories --</option>
                    </select>
                </div>
            </div>

            <!-- Data Table -->
            <div class="table-responsive">
                <table id="order-listing" class="table table-hover table-striped table-bordered align-middle">
                    <thead class="table-primary">
                        <tr>
                            <th class="text-center">Images</th>
                            <th class="text-start">Item Name</th>
                            <th class="text-start">Category Name</th>
                            <th class="text-start">Price</th>
                          
                            <th class="text-start">Description</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <!-- Product Images Carousel -->
                                <td class="text-center">
                                    @if (item.ProductImages != null && item.ProductImages.Any())
                                    {
                                        var firstImage = item.ProductImages.FirstOrDefault()?.ImageUrl;

                                        if (!string.IsNullOrEmpty(firstImage))
                                        {
                                            <img src="@firstImage"
                                                 alt="@item.ProductName"
                                                 class="img-thumbnail"
                                                 style="width:80px; height:80px; object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <span class="text-muted">No image</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">No image</span>
                                    }
                                </td>






                                <!-- Product Name -->
                                <td class="text-start">@item.ProductName</td>

                                <!-- Category Name -->
                                <td class="text-start">
                                    @{
                                        var category = ((List<Category>)ViewBag.lstCategories)
                                        .FirstOrDefault(c => c.CategoryId == item.CategoryId);
                                    }
                                    @category?.CategoryName
                                </td>

                                <!-- Price -->
                                <td class="text-start">@item.Price $</td>
                             

                                <!-- Description -->
                                <td class="text-start">@item.Description</td>

                               

                                <!-- Actions -->
                                <td class="text-center">
                                    <a asp-controller="Items" asp-action="Edit" asp-route-ProductId="@item.ProductId"
                                       class="btn btn-info btn-sm me-1">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a asp-controller="Items" asp-action="ProductList" asp-route-ProductId="@item.ProductId"
                                       class="btn btn-outline-success btn-sm me-1">
                                        <i class="bi bi-eye"></i> Show Details
                                    </a>
                                    <a asp-controller="Items" asp-action="Delete" asp-route-ProductId="@item.ProductId"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Are you sure you want to delete this product?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

@section Scripts
{

    <script src="~/Admin/assets/vendors/datatables.net/jquery.dataTables.js"></script>
    <script src="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.js"></script>
    <script src="~/Admin/assets/js/data-table.js"></script>



    <script>
        function Search(dropDown)
        {
            var id=$(dropDown).val();
          
            window.location.href="/admin/Items/Search?id="+id;
            
        }
    </script> 





}


