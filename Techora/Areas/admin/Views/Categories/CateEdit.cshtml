@model List<Category>

@section Styles {
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.css"> <!-- End plugin css for this page -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"> <!-- DataTables + Bootstrap 5 CSS -->
}

<div class="container ">

    <!-- Top Cards Row -->
    @* <div class="row justify-content-center mb-4">
        <!-- Borrowed Card -->
        <div class="col-md-3">
            <div class="card text-center shadow border-success">
                <div class="card-body">
                    <h5 class="card-title text-success">Number Of Categories</h5>

                    <h4 class="fw-light border-top pb-2 mb-2">@Model.lstCategory.Count category</h4>

                </div>
            </div>
        </div>

        <!-- Annual Profit Card -->
        <div class="col-md-3">
            <div class="card text-center shadow border-danger">
                <div class="card-body">
                    <h5 class="card-title text-danger">Number Of Items</h5>

                    <h4 class="fw-light border-top pb-2 mb-2">@Model.lstProduct.Count Item</h4>

                </div>
            </div>
        </div>
    </div> *@

    <!-- Table Card -->
    <div class="card shadow">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="card-title mb-0">Categories</h6>
                <a asp-controller="Categories" asp-action="Edit" class="btn btn-success btn-sm">
                    <i class="bi bi-plus-lg"></i> New
                </a>
            </div>

            <div class="table-responsive">
                <table id="order-listing" class="table table-hover table-striped table-bordered align-middle">
                    <thead class="table-primary">
                        <tr>
                            <th class="text-center"></th>
                            <th class="text-start">Category Name</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model)
                        {
                            <tr>
                                <td class="text-center">
                                   
                                    
                                    @if (!string.IsNullOrEmpty(cat.ImageName))
                                    {
                                        <img src="~/Admin/CateoryImges/@cat.ImageName"
                                             alt="@cat.CategoryName"
                                             class="img-thumbnail"
                                             style="width:80px; height:80px; object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">No image</span>
                                    }
                                </td>
                                <td class="text-start">@cat.CategoryName</td>
                                <td class="text-center">
                                    <a asp-controller="Categories" asp-action="Edit" asp-route-categoryId="@cat.CategoryId"
                                       class="btn btn-info btn-sm me-1">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a asp-controller="Items" asp-action="ProductList" asp-route-categoryId="@cat.CategoryId"
                                       class="btn btn-outline-success btn-sm me-1">
                                        <i class="bi bi-pencil-square"></i> Items
                                    </a>

                                    <a asp-controller="Categories" asp-action="Delete" asp-route-categoryId="@cat.CategoryId"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('Are you sure you want to delete this category?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>


@section Scripts
{

    <script src="~/Admin/assets/vendors/datatables.net/jquery.dataTables.js"></script>
    <script src="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.js"></script>
    <script src="~/Admin/assets/js/data-table.js"></script>

}
