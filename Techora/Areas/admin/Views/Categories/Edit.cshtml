@model Category

@section Styles {
    <!-- Plugin css for this page -->
    <link rel="stylesheet" href="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.css"> <!-- End plugin css for this page -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"> <!-- DataTables + Bootstrap 5 CSS -->
}




<div class="content-wrapper">
    <div class="page-header">
        <h3 class="card-title mb-3 ">Category Form</h3>
       
    </div>
 <div class="row g-3">
    <!-- Form Section -->
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body">
                
                <p class="card-description text-muted">Fill in the details below</p>

                <form class="forms-sample" method="post" enctype="multipart/form-data"
                      asp-controller="Categories" asp-action="Save" role="form">

                    <!-- Hidden fields -->
                    <input type="hidden" asp-for="CategoryId" />
                    <input type="hidden" asp-for="ImageName" />
                    <input type="hidden" asp-for="CreatedBy" />
                    <input type="hidden" asp-for="CreatedDate" />
                    <input type="hidden" asp-for="CurrentState" />

                    <!-- Category Name -->
                    <div class="mb-3">
                        <label asp-for="CategoryName" class="form-label fw-semibold">Category Name</label>
                        <input asp-for="CategoryName" type="text" class="form-control" placeholder="Enter category name" />
                        <span class="text-danger small" asp-validation-for="CategoryName"></span>
                    </div>

                    <!-- Image Upload -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Category Image</label>
                        <input asp-for="ImageName" type="file" name="Files"
                               class="form-control"
                               onchange="upload.UploadDefaultImg(event)"
                               accept=".jpg, .jpeg, .png, .gif" />
                        <small class="text-muted">Supported formats: JPG, PNG, GIF</small>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" formmethod="post" class="btn btn-gradient-primary px-4">
                            <i class="mdi mdi-content-save-outline me-1"></i> Save
                        </button>
                        <button type="reset" class="btn btn-light px-4">
                            <i class="mdi mdi-plus-circle-outline me-1"></i> New
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Image Preview Section -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body text-center">
                <h6 class="fw-semibold mb-3">Preview</h6>
                <div id="tbImgSrc" class="border rounded p-2 bg-light">
                        <img src="~/Admin/CateoryImges/@Model.ImageName"
                         class="img-fluid rounded"
                         style="max-height: 300px; object-fit: cover;" />
                </div>
                <span id="tbImgName" class="d-block mt-2 text-muted small"></span>
            </div>
        </div>
    </div>
    
</div>

</div>

@section Scripts
{
    <script>
        var upload = {
            UploadDefaultImg: function (e) {
                const file = e.target.files[0];
                const reader = new FileReader();

                reader.onloadend = () => {
                    const courseMediaImgName = file.name;
                    const courseMediaImgBase64 = reader.result.slice(reader.result.indexOf('base64,') + 7);

                    $("#tbImgName").html(courseMediaImgName);
                    $("#tbImgSrc").html(
                        `<img class="thumbnail" src="${reader.result}" style="width: 200px; height: 300px; border-radius: 5px; border: 1px solid #d9d9d9; padding: 1px;" />`
                    );
                };

                reader.readAsDataURL(file);
            }
        };
    </script>




    <script src="~/Admin/assets/vendors/datatables.net/jquery.dataTables.js"></script>
    <script src="~/Admin/assets/vendors/datatables.net-bs4/dataTables.bootstrap4.js"></script>
    <script src="~/Admin/assets/js/data-table.js"></script>

}
